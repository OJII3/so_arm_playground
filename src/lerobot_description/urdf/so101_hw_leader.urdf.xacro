<?xml version="1.0"?>
<robot name="so101" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Base links/joints -->
  <xacro:include filename="$(find lerobot_description)/urdf/so101_base.xacro" />

  <!-- Use Feetech hardware ros2_control for leader arm (read-only, no position control) -->
  <xacro:include filename="$(find lerobot_description)/urdf/so101_ros2_control_feetech_leader.xacro" />

</robot>
