<mujoco model="so101_minimal">
  <compiler angle="radian"/>

  <option timestep="0.005" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.04" armature="0.002"/>
    <geom type="capsule" size="0.012" rgba="0.2 0.45 0.8 1"/>
    <position kp="12" kv="1.2"/>
  </default>

  <worldbody>
    <light pos="0 -0.4 0.8" dir="0 0 -1"/>
    <geom name="table" type="plane" size="0.45 0.45 0.02" rgba="0.18 0.18 0.18 1"/>

    <body name="base" pos="0 0 0.045">
      <geom name="base_geom" type="cylinder" size="0.045 0.025" rgba="0.15 0.15 0.16 1"/>
      <joint name="shoulder_pan" type="hinge" axis="0 0 1" range="-1.745 1.745"/>

      <body name="shoulder" pos="0 0 0.025">
        <joint name="shoulder_lift" type="hinge" axis="0 1 0" range="-1.658 1.658"/>
        <geom name="upper_arm_geom" fromto="0 0 0 0.115 0 0" size="0.014"/>

        <body name="elbow" pos="0.115 0 0">
          <joint name="elbow_flex" type="hinge" axis="0 1 0" range="-1.92 1.92"/>
          <geom name="forearm_geom" fromto="0 0 0 0.135 0 0" size="0.012"/>

          <body name="wrist" pos="0.135 0 0">
            <joint name="wrist_flex" type="hinge" axis="0 1 0" range="-1.745 1.745"/>
            <geom name="wrist_geom" fromto="0 0 0 0.055 0 0" size="0.01" rgba="0.8 0.45 0.2 1"/>

            <body name="tool" pos="0.055 0 0">
              <joint name="wrist_roll" type="hinge" axis="1 0 0" range="-3.1416 3.1416"/>
              <geom name="tool_geom" type="box" size="0.025 0.012 0.012" rgba="0.85 0.85 0.85 1"/>
              <body name="gripper_left" pos="0.025 0.018 0">
                <joint name="gripper" type="slide" axis="0 1 0" range="0 0.025"/>
                <geom name="gripper_left_geom" type="box" size="0.025 0.004 0.012" rgba="0.95 0.95 0.95 1"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="shoulder_pan.pos" joint="shoulder_pan" ctrlrange="-1.745 1.745"/>
    <position name="shoulder_lift.pos" joint="shoulder_lift" ctrlrange="-1.658 1.658"/>
    <position name="elbow_flex.pos" joint="elbow_flex" ctrlrange="-1.92 1.92"/>
    <position name="wrist_flex.pos" joint="wrist_flex" ctrlrange="-1.745 1.745"/>
    <position name="wrist_roll.pos" joint="wrist_roll" ctrlrange="-3.1416 3.1416"/>
    <position name="gripper.pos" joint="gripper" ctrlrange="0 0.025"/>
  </actuator>
</mujoco>
