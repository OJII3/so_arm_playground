# ros2_ws に入ったら ROS 2 開発環境を自動で有効化する.
# nix-ros-overlay は Linux 専用のため, Linux でのみルート flake の `#ros` を読み込む.
# macOS では native に動かせないので podman を案内する.

if [[ "$(uname -s)" == "Linux" ]]; then
  # ルート flake の devShells.<system>.ros (ros2, colcon が使える).
  use flake "$(git rev-parse --show-toplevel)#ros"

  # colcon build 済みなら, ビルドしたワークスペースを overlay source する.
  # (cd で抜けると direnv が環境を巻き戻すのでクリーン)
  watch_file install/setup.bash
  if [[ -f install/setup.bash ]]; then
    source install/setup.bash
  fi
else
  echo "direnv: ros2 の nix シェルは Linux 専用です。" >&2
  echo "        macOS では ./podman/run.sh を使ってください。" >&2
fi
