# ros2_ws に入ったら開発環境を自動で有効化する.
# Linux: ルート flake の `#ros` (ROS 2 + colcon).
# macOS: ルート flake の `#robostack` (micromamba + ROS 2).
# いずれも colcon build 済みなら install/setup.bash を source する.

if [[ "$(uname -s)" == "Linux" ]]; then
  use flake "$(git rev-parse --show-toplevel)#ros"
else
  use flake "$(git rev-parse --show-toplevel)#robostack"
fi

watch_file install/setup.bash
if [[ -f install/setup.bash ]]; then
  source install/setup.bash
fi
