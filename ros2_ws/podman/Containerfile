# SO-101 ROS 2 (Jazzy) コンテナ.
# nix-ros-overlay が使えない環境 (macOS の podman machine 等) や、
# 手早く実機/シミュレーションを動かしたいときの退避路.
FROM ros:jazzy-ros-base

SHELL ["/bin/bash", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
      libserial-dev \
      python3-colcon-common-extensions \
      socat \
      unzip \
 && rm -rf /var/lib/apt/lists/*

# zenoh-bridge-ros2dds: コンテナ内 DDS と LAN 上の ROS 2 を Zenoh 経由で接続.
ARG ZENOH_BRIDGE_VERSION=1.5.0
RUN ARCH=$(dpkg --print-architecture) \
 && case "$ARCH" in \
      arm64) ZENOH_ARCH="aarch64-unknown-linux-gnu" ;; \
      amd64) ZENOH_ARCH="x86_64-unknown-linux-gnu" ;; \
      *) echo "unsupported arch: $ARCH" >&2; exit 1 ;; \
    esac \
 && curl -sSL "https://github.com/eclipse-zenoh/zenoh-plugin-ros2dds/releases/download/${ZENOH_BRIDGE_VERSION}/zenoh-plugin-ros2dds-${ZENOH_BRIDGE_VERSION}-${ZENOH_ARCH}-standalone.zip" \
      -o /tmp/zenoh.zip \
 && unzip -j /tmp/zenoh.zip "zenoh-bridge-ros2dds" -d /usr/local/bin/ \
 && chmod +x /usr/local/bin/zenoh-bridge-ros2dds \
 && rm -f /tmp/zenoh.zip

WORKDIR /ros2_ws
COPY src ./src

# package.xml から ROS 依存を解決してビルド.
RUN apt-get update \
 && rosdep update \
 && rosdep install --from-paths src --ignore-src -r -y \
 && rm -rf /var/lib/apt/lists/*
RUN source /opt/ros/jazzy/setup.bash \
 && colcon build --symlink-install --parallel-workers 1 \
      --executor sequential

# シェル起動時に自動 source.
RUN echo "source /opt/ros/jazzy/setup.bash" >> /root/.bashrc \
 && echo "source /ros2_ws/install/setup.bash" >> /root/.bashrc

CMD ["bash"]
