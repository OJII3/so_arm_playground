# SO-101 ROS 2 (Jazzy) コンテナ.
# nix-ros-overlay が使えない環境 (macOS の podman machine 等) や、
# 手早く実機/シミュレーションを動かしたいときの退避路.
#
# 注意: macOS の `podman machine` (Linux VM) はホスト USB を直接渡せないため、
# このコンテナでの実機制御は Linux ホスト上で実行すること.
FROM ros:jazzy-ros-base

SHELL ["/bin/bash", "-c"]

# rosdep キーに無い/明示しておきたいシステム依存.
RUN apt-get update && apt-get install -y --no-install-recommends \
      libserial-dev \
      python3-colcon-common-extensions \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /ros2_ws
COPY src ./src

# package.xml から ROS 依存を解決してビルド.
RUN apt-get update \
 && rosdep update \
 && rosdep install --from-paths src --ignore-src -r -y \
 && rm -rf /var/lib/apt/lists/*
RUN source /opt/ros/jazzy/setup.bash \
 && colcon build --symlink-install --parallel-workers 1 \
      --executor sequential

# シェル起動時に自動 source.
RUN echo "source /opt/ros/jazzy/setup.bash" >> /root/.bashrc \
 && echo "source /ros2_ws/install/setup.bash" >> /root/.bashrc

CMD ["bash"]
